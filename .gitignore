# =============================================================
# OmniClaw - Hardened .gitignore
# Purpose: Restricted git tracking to Documentation & Workforce Registry
# =============================================================

# 1. Ignore EVERYTHING by default
/*

# 2. Allow Git to track the root configuration and documentation
!/.gitignore
!/README.md
!/README-vn.md
!/LICENSE
!/omniclaw.bat

# 3. Allow authorized "Operating System" Documentation
!/core/
/core/*
!/core/docs/
!/core/docs/**
!/core/scripts/
!/core/scripts/**

# 4. Allow authorized Workforce Registry
!/ecosystem/
/ecosystem/*
!/ecosystem/workforce/
!/ecosystem/workforce/**
!/ecosystem/skills/
!/ecosystem/skills/**
!/ecosystem/plugins/
!/ecosystem/plugins/**
!/ecosystem/tools/
!/ecosystem/tools/**
!/ecosystem/ui_components/
!/ecosystem/ui_components/**
!/ecosystem/bridges/
!/ecosystem/bridges/**
!/docs/
!/docs/**

# 5. Allow authorized Vault Structure & Media Assets
!/vault/
/vault/*
!/vault/_DIR_IDENTITY.md
!/vault/archives/
/vault/archives/*
!/vault/archives/_DIR_IDENTITY.md
!/vault/assets/
/vault/assets/*
!/vault/assets/_DIR_IDENTITY.md
!/vault/assets/media/
!/vault/assets/media/**
!/vault/quarantine/
/vault/quarantine/*
!/vault/quarantine/_DIR_IDENTITY.md
!/vault/tmp/
/vault/tmp/*
!/vault/tmp/_DIR_IDENTITY.md

# 6. Global exclusions for common clutter in whitelisted zones
**/.DS_Store
**/Thumbs.db
**/node_modules/
**/__pycache__/
**/*.pyc
**/.venv/
**/venv/
**/dist/
**/build/
**/*.tmp
**/*.bak

# 7. Secrets (Double-Safety)
.env
.env.*
secrets/
**/*.key
**/*.pem

# 8. Allow authorized Rules Directory
!/brain/
/brain/*
!/brain/rules/
!/brain/rules/**

# 9. Allow authorized Registry Directory
!/brain/
/brain/*
!/brain/registry/
!/brain/registry/**
!/brain/agents/
!/brain/agents/**
!/brain/indices/
!/brain/indices/**
!/brain/chroma_db/
!/brain/chroma_db/**

# Ignore systemic logs and massive auto-generated JSONs in registry
brain/registry/*.log
brain/registry/OMA_SYSTEM_MAP*.json





# 10. Memory - Corp Agents Roster (Ignore Agent Profiles, keep folder)
!/brain/memory/
/brain/memory/*
!/brain/memory/_DIR_IDENTITY.md
!/brain/memory/corp_memory/
/brain/memory/corp_memory/*
!/brain/memory/corp_memory/agents/
/brain/memory/corp_memory/agents/*
!/brain/memory/corp_memory/agents/_DIR_IDENTITY.md
!/brain/memory/corp_memory/agents/.gitkeep

# 11. Memory - Brainstorms Buffer (Ignore volatile ideation logs)
!/brain/memory/corp_memory/brainstorms/
/brain/memory/corp_memory/brainstorms/*
!/brain/memory/corp_memory/brainstorms/_DIR_IDENTITY.md
!/brain/memory/corp_memory/brainstorms/brainstormtemplate.md
!/brain/memory/corp_memory/brainstorms/.gitkeep

# 12. Memory - Corp Departments Ledgers (Ignore volatile ledger logs)
!/brain/memory/corp_memory/departments/
/brain/memory/corp_memory/departments/*
!/brain/memory/corp_memory/departments/_DIR_IDENTITY.md
!/brain/memory/corp_memory/departments/dept_memorytemplate.md
!/brain/memory/corp_memory/departments/.gitkeep

# 13. Memory - System Gaps Logging (Ignore volatile tickets)
!/brain/memory/corp_memory/gaps/
/brain/memory/corp_memory/gaps/*
!/brain/memory/corp_memory/gaps/_DIR_IDENTITY.md
!/brain/memory/corp_memory/gaps/gap_reporttemplate.md
!/brain/memory/corp_memory/gaps/.gitkeep

# 14. Memory - Global Strategy (Track the ledger but block clutter)
!/brain/memory/corp_memory/global/
/brain/memory/corp_memory/global/*
!/brain/memory/corp_memory/global/_DIR_IDENTITY.md
!/brain/memory/corp_memory/global/global_ceo_ledger.md
!/brain/memory/corp_memory/global/.gitkeep

# 15. Memory - System Heuristics (Track Adaptive Patches)
!/brain/memory/corp_memory/patterns/
/brain/memory/corp_memory/patterns/*
!/brain/memory/corp_memory/patterns/_DIR_IDENTITY.md
!/brain/memory/corp_memory/patterns/system_heuristics.md
!/brain/memory/corp_memory/patterns/.gitkeep

# 16. Memory - System Proposals (Block volatile proposals, track structure only)
!/brain/memory/corp_memory/proposals/
/brain/memory/corp_memory/proposals/*
!/brain/memory/corp_memory/proposals/_DIR_IDENTITY.md
!/brain/memory/corp_memory/proposals/proposaltemplate.md
!/brain/memory/corp_memory/proposals/.gitkeep
