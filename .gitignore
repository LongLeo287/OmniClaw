logs/
*.log
*.log.*

# Backup ZIPs (too large for git)
backups/
.gitnexus

# ─── OmniClaw Data Vault Boundaries ────────────────────────────
# Globally ignore raw storage formats handled by Dual-Sync:
*.sqlite
*.sqlite3
*.db
*.webp
*.mp4
*.mkv
*.webm

# ─── Tool Chains ───────────────────────────────────────────────
system/ops/tools/rclone/

# ─── Core Brain Memories and Embeddings (Sync to HF/GDrive) ────
brain/memory/
!brain/memory/.gitkeep
brain/rag_storage/
!brain/rag_storage/.gitkeep
brain/corp/memory/*/*
!brain/corp/memory/*/.gitkeep
system/telemetry/receipts/
# Releases
releases/
*.zip

# --- Legacy Quarantine -------------------------------------
system/security/QUARANTINE/*
!system/security/QUARANTINE/.gitkeep

# --- Orphaned Embedded Repos (non-submodule gitlinks) ------
system/security/rules/prompts/
!system/security/rules/prompts/.gitkeep

# AI OS Vector Database
brain/memory/qdrant_db/
