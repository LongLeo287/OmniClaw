{
    "name": "taipy-gui",
    "version": "4.2.0",
    "private": true,
    "dependencies": {
        "@emotion/react": "^11.10.0",
        "@emotion/styled": "^11.10.0",
        "@mui/icons-material": "^7.1.0",
        "@mui/material": "^7.1.0",
        "@mui/x-date-pickers": "^8.3.0",
        "@mui/x-tree-view": "^8.3.0",
        "apache-arrow": "^16.1.0",
        "axios": "^1.2.0",
        "better-react-mathjax": "^3.0.0",
        "date-fns": "^4.1.0",
        "date-fns-tz": "^3.1.3",
        "lodash": "4.17",
        "nanoid": "^5.0.7",
        "notistack": "^3.0.0",
        "plotly.js": "^3.0.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-error-boundary": "^6.0.0",
        "react-helmet-async": "^3.0.0",
        "react-markdown": "^10.1.0",
        "react-plotly.js": "^2.5.1",
        "react-router": "^7.12.0",
        "react-window": "^2.2.7",
        "react-window-infinite-loader": "^2.0.1",
        "socket.io-client": "^4.3.2",
        "sprintf-js": "^1.1.2"
    },
    "overrides": {
        "react": "$react",
        "react-dom": "$react-dom",
        "react-is": "$react",
        "glob": "^13.0.6"
    },
    "scripts": {
        "inst": "npm i",
        "start": "echo no start see python",
        "build:dev": "webpack --mode development",
        "build": "webpack --mode production",
        "test": "cross-env TZ=UTC jest",
        "lint": "eslint --ext .ts,.tsx",
        "lint:fix": "npm run lint -- --fix",
        "coverage": "npm test -- --coverage",
        "types:unformatted": "dts-bundle-generator -o packaging/taipy-gui.gen.d.ts src/extensions/exports.ts",
        "types:format": "prettier --write --parser typescript --tab-width 4 --use-tabs false packaging/taipy-gui.gen.d.ts",
        "types:header": "node scripts/add-header.js packaging/taipy-gui.d.ts",
        "types": "npm run types:unformatted && npm run types:format && node -e \"require('fs').copyFileSync('packaging/taipy-gui.gen.d.ts','packaging/taipy-gui.d.ts')\" && npm run types:header",
        "doc": "typedoc --plugin typedoc-plugin-markdown --excludeNotDocumented --disableSources src/extensions/exports.ts",
        "doc.json": "typedoc --json docs/taipy-gui.json src/extensions/exports.ts",
        "mkdocs": "typedoc --options typedoc-mkdocs.json"
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged"
        }
    },
    "lint-staged": {
        "src/**/*.(ts|tsx)": [
            "npm run --silent lint:fix"
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.3",
        "@eslint/eslintrc": "^3.3.0",
        "@eslint/js": "^9.22.0",
        "@testing-library/jest-dom": "^6.1.3",
        "@testing-library/react": "^16.0.0",
        "@testing-library/user-event": "^14.2.1",
        "@types/css-mediaquery": "^0.1.1",
        "@types/jest": "^30.0.0",
        "@types/lodash": "^4.14.177",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.2",
        "@types/react-plotly.js": "^2.5.0",
        "@types/react-router": "^5.1.20",
        "@types/sprintf-js": "^1.1.2",
        "@typescript-eslint/eslint-plugin": "^8.5.0",
        "@typescript-eslint/parser": "^8.5.0",
        "add-asset-html-webpack-plugin": "^6.0.0",
        "autoprefixer": "^10.4.0",
        "copy-webpack-plugin": "^14.0.0",
        "cross-env": "^10.0.0",
        "css-loader": "^7.1.0",
        "css-mediaquery": "^0.1.2",
        "dotenv-webpack": "^9.0.0",
        "dts-bundle-generator": "^7.2.0",
        "eslint": "^9.39.4",
        "eslint-plugin-react": "^7.26.1",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-tsdoc": "^0.5.2",
        "eslint-webpack-plugin": "^5.0.0",
        "generate-json-webpack-plugin": "^2.0.0",
        "generate-package-json-webpack-plugin": "^2.7.0",
        "html-webpack-plugin": "^5.5.0",
        "husky": "^9.0.11",
        "jest": "^30.3.0",
        "jest-environment-jsdom": "^30.3.0",
        "jest-websocket-mock": "^2.2.1",
        "lint-staged": "^16.4.0",
        "mock-socket": "^9.0.7",
        "mock-xmlhttprequest": "^8.2.0",
        "prettier": "^3.8.1",
        "ts-jest": "^29.4.9",
        "ts-jest-mock-import-meta": "^1.2.0",
        "ts-loader": "^9.2.6",
        "typedoc": "^0.28.1",
        "typedoc-plugin-markdown": "^4.5.2",
        "typescript": "^5.9.3",
        "webpack": "^5.61.0",
        "webpack-cli": "^7.0.2",
        "webpack-node-externals": "^3.0.0"
    }
}
